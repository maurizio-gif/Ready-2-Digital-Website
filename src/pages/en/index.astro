---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../utils/url';
---

<BaseLayout
  title="Digital Process Architecture"
  description="Ready2Digital — We are architects of your business processes. We start from the audit, map the current state, identify the gaps — then we choose the technology."
  lang="en"
>
  <section style="padding-block: 6rem; text-align: center;">
    <div class="container">
      <span class="eyebrow">Coming soon</span>
      <h1 style="font-family: var(--font-display); font-size: clamp(2.5rem, 7vw, 4rem); font-weight: 800; margin-top: 1rem; color: var(--color-dark);">
        English version<br>coming soon
      </h1>
      <p style="font-size: 1.25rem; color: var(--color-gray-mid); margin-top: 1.5rem; max-width: 480px; margin-inline: auto; line-height: 1.65;">
        Meanwhile, you can explore our Italian site or contact us directly.
      </p>
      <div style="margin-top: 2.5rem; display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href={withBase('/')} class="btn btn-primary">Italian Site</a>
        <a href={withBase('/contatti')} class="btn btn-outline-dark">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>
