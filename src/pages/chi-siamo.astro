---
import BaseLayout from '../layouts/BaseLayout.astro';
import NodeDecoration from '../components/NodeDecoration.astro';
import { withBase } from '../utils/url';
---

<BaseLayout
  title="Chi Siamo"
  description="Ready2Digital nasce dall'esperienza diretta di Maurizio Taruggi, titolare dello storico Athlon Club 4.0 di Roma. Dalla digitalizzazione di un club nato nel 1973 a un metodo: audit, architettura, implementazione."
>

  <!-- HERO -->
  <section class="page-hero" style="background: var(--color-dark);">
    <div class="hero__bg-decoration" aria-hidden="true">
      <NodeDecoration color="rgba(255,96,0,0.06)" />
    </div>
    <div class="container page-hero__content">
      <span class="eyebrow">La nostra storia</span>
      <h1 class="page-hero__title">La strategia<br>prima degli strumenti</h1>
      <p class="page-hero__sub">
        Ready2Digital nasce da un'esperienza diretta: non da una slide di consulenza.
      </p>
    </div>
  </section>

  <!-- STORIA -->
  <section class="section storia">
    <div class="container storia__inner">
      <div class="storia__text reveal">
        <span class="eyebrow">Maurizio Taruggi · Founder &amp; CEO</span>
        <h2 class="section-title">Da imprenditore<br>del fitness ad architetto<br>digitale</h2>
        <div class="divider"></div>
        <p>
          Maurizio Taruggi non viene dalla teoria. Viene dal campo. È il titolare di
          <strong>Athlon Club 4.0</strong>, uno storico club sportivo di Roma Nord nato nel
          1973: nuoto, fitness, pattinaggio su ghiaccio. Oltre cinquant'anni di tradizione,
          gestiti ogni giorno dall'interno — con i suoi numeri reali, i suoi turni, i suoi clienti.
        </p>
        <p>
          La sua formazione unisce management e sport: un Master in Management alla LUISS,
          un Master in International Marketing alla European School of Economics di New York,
          e un Master in Sports Management LUISS/CONI. È stato Direttore Sportivo della
          Federazione Italiana Nuoto. Una doppia competenza — gestionale e operativa — che
          è esattamente ciò che manca quando si parla di digitalizzazione nel mondo dei servizi.
        </p>
        <p>
          Gestendo Athlon ha capito una cosa: la soluzione non era comprare software costosi
          senza una strategia. Era ripensare come i processi funzionavano — prenotazioni,
          abbonamenti, accessi, comunicazione, dati — e poi abilitarli con la tecnologia giusta.
          Portali clienti, totem di check-in, gestione degli abbonamenti online: la
          digitalizzazione completa di Athlon ha portato a marginalità superiori alla media di
          settore, con un'incidenza del costo del personale ridotta al 25% — senza sacrificare
          la qualità del lavoro, anzi valorizzando le risorse umane.
        </p>
        <p>
          Oggi Ready2Digital è la materializzazione di quella visione. Non veniamo da grandi
          agenzie di marketing. Veniamo dall'operatività. Sappiamo cosa significa gestire
          margini, costi, flussi di cassa, qualità del servizio. E sappiamo che la
          digitalizzazione è la leva più potente per migliorare tutto questo simultaneamente.
        </p>
      </div>
      <div class="storia__photo reveal">
        <figure class="storia__figure">
          <img
            src={withBase('/images/maurizio-taruggi.jpg')}
            alt="Maurizio Taruggi, Founder & CEO di Ready2Digital, durante un intervento"
            width="1536"
            height="2048"
            loading="lazy"
          />
          <figcaption class="storia__caption">
            <span class="storia__caption-name">Maurizio Taruggi</span>
            <span class="storia__caption-role">Founder &amp; CEO, Ready2Digital</span>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- FORMAZIONE & CREDENZIALI -->
  <section class="section formazione" style="background: var(--color-light);">
    <div class="container">
      <div class="formazione__intro reveal">
        <span class="eyebrow">Formazione &amp; Credenziali</span>
        <h2 class="section-title">Management e sport,<br>nello stesso percorso</h2>
        <div class="divider"></div>
        <p class="formazione__lead">
          Una formazione che unisce competenza gestionale e conoscenza profonda del settore
          sportivo — la stessa doppia prospettiva che mettiamo in ogni progetto.
        </p>
      </div>

      <div class="formazione__grid">
        <div class="credenziale reveal">
          <span class="credenziale__tag">Formazione</span>
          <h3 class="credenziale__title">Master in Management</h3>
          <p class="credenziale__org">LUISS Guido Carli</p>
        </div>
        <div class="credenziale reveal">
          <span class="credenziale__tag">Formazione</span>
          <h3 class="credenziale__title">Master in International Marketing</h3>
          <p class="credenziale__org">European School of Economics — New York</p>
        </div>
        <div class="credenziale reveal">
          <span class="credenziale__tag">Formazione</span>
          <h3 class="credenziale__title">Master in Sports Management</h3>
          <p class="credenziale__org">LUISS / CONI</p>
        </div>
        <div class="credenziale reveal">
          <span class="credenziale__tag">Qualifica</span>
          <h3 class="credenziale__title">Direttore Sportivo</h3>
          <p class="credenziale__org">Federazione Italiana Nuoto (FIN)</p>
        </div>
        <div class="credenziale reveal">
          <span class="credenziale__tag">Impresa</span>
          <h3 class="credenziale__title">Titolare Athlon Club 4.0</h3>
          <p class="credenziale__org">Storico club sportivo di Roma, dal 1973</p>
        </div>
      </div>
    </div>
  </section>

  <!-- VISIONE -->
  <section class="section visione">
    <div class="container visione__inner">
      <div class="visione__content reveal">
        <span class="eyebrow">La nostra visione</span>
        <h2 class="section-title">Digitalizzazione è strategia,<br>non tecnologia</h2>
        <div class="divider"></div>
        <div class="visione__text">
          <p>
            Tante volte si è parlato di strumenti come soluzione unica ai problemi aziendali.
            La realtà è che in qualsiasi settore, quando si implementa uno strumento senza una
            visione di processo, l'implementazione è parziale, i puntini non si connettono,
            e i risultati non arrivano.
          </p>
          <p>
            Quello che facciamo è partire dall'obiettivo: capire lo stato attuale, mappare i gap,
            identificare le soluzioni con il giusto grado di profondità per la tipologia di cliente.
            Solo allora scegliamo gli strumenti.
          </p>
        </div>
      </div>
      <div class="visione__decoration" aria-hidden="true">
        <NodeDecoration color="rgba(255,96,0,0.10)" />
      </div>
    </div>
  </section>

  <!-- VALORI -->
  <section class="section valori">
    <div class="container">
      <div class="valori__intro reveal">
        <span class="eyebrow">I nostri principi</span>
        <h2 class="section-title">Quello in cui crediamo</h2>
      </div>
      <div class="valori__grid">
        <div class="valore-card reveal">
          <div class="valore-card__number">01</div>
          <h3 class="valore-card__title">Prima l'audit</h3>
          <p class="valore-card__desc">
            Non proponiamo mai una soluzione senza capire la situazione. Ogni progetto
            inizia con un'analisi approfondita dell'architettura esistente.
          </p>
        </div>
        <div class="valore-card reveal">
          <div class="valore-card__number">02</div>
          <h3 class="valore-card__title">Misurabilità</h3>
          <p class="valore-card__desc">
            Ogni progetto ha KPI definiti. I risultati si misurano. Non lavoriamo
            per impressionare — lavoriamo per produrre impatto concreto.
          </p>
        </div>
        <div class="valore-card reveal">
          <div class="valore-card__number">03</div>
          <h3 class="valore-card__title">Settore specifico</h3>
          <p class="valore-card__desc">
            Fitness & Sport non è un contesto generico. È la nostra specializzazione.
            Conosciamo dall'interno le sfide di un club, una palestra, un centro sportivo.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-block" style="background: var(--color-dark);">
    <div class="container cta-block__inner reveal">
      <h2 class="section-title" style="color: var(--color-white);">
        Inizia dall'audit
      </h2>
      <p style="color: rgba(255,255,255,0.7); font-size: var(--text-lg);">
        Il primo passo è sempre capire la situazione. Prenota una call gratuita.
      </p>
      <a href={withBase('/contatti')} class="btn btn-primary">Prenota un Audit</a>
    </div>
  </section>

</BaseLayout>

<style>
  .page-hero {
    position: relative;
    padding-block: clamp(var(--space-16), 10vw, var(--space-24));
    overflow: hidden;
    color: var(--color-white);
  }

  .hero__bg-decoration {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .page-hero__content {
    position: relative;
    z-index: 1;
    max-width: 700px;
  }

  .page-hero__title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-4xl), 7vw, var(--text-6xl));
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--color-white);
    margin-top: var(--space-4);
  }

  .page-hero__sub {
    margin-top: var(--space-6);
    font-size: var(--text-xl);
    color: rgba(255,255,255,0.7);
    max-width: 500px;
  }

  /* STORIA */
  .storia__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  .storia__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .storia__text p {
    font-size: var(--text-lg);
    color: var(--color-gray-mid);
    line-height: 1.75;
  }

  .storia__figure {
    position: relative;
    margin: 0;
    aspect-ratio: 3/4;
    max-width: 420px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--color-charcoal);
    box-shadow: var(--shadow-lg);
  }

  .storia__figure img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Zoom toward the subject (upper-right) and crop the foreground audience */
    transform: scale(1.5);
    transform-origin: 70% 28%;
  }

  .storia__caption {
    position: absolute;
    inset: auto 0 0 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-8) var(--space-6) var(--space-5);
    background: linear-gradient(to top, rgba(26,26,26,0.92) 0%, rgba(26,26,26,0.55) 55%, rgba(26,26,26,0) 100%);
    color: var(--color-white);
  }

  .storia__caption-name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    line-height: 1.1;
  }

  .storia__caption-role {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.75);
  }

  /* FORMAZIONE */
  .formazione__intro {
    max-width: 680px;
    margin-bottom: var(--space-12);
  }

  .formazione__lead {
    font-size: var(--text-lg);
    color: var(--color-gray-mid);
    line-height: 1.75;
  }

  .formazione__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .credenziale {
    background: var(--color-white);
    border: 1px solid var(--color-gray-light);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    border-top: 3px solid var(--color-orange);
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .credenziale:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .credenziale__tag {
    align-self: flex-start;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-orange);
  }

  .credenziale__title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-dark);
    line-height: 1.2;
  }

  .credenziale__org {
    font-size: var(--text-sm);
    color: var(--color-gray-mid);
    line-height: 1.5;
    margin-top: auto;
  }

  /* VISIONE */
  .visione__inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  .visione__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .visione__text p {
    font-size: var(--text-lg);
    color: var(--color-gray-mid);
    line-height: 1.75;
  }

  .visione__decoration {
    width: 100%;
    aspect-ratio: 1;
    max-width: 400px;
    justify-self: end;
  }

  /* VALORI */
  .valori__intro {
    margin-bottom: var(--space-12);
  }

  .valori__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .valore-card {
    padding: var(--space-10) var(--space-8);
    border: 1px solid var(--color-gray-light);
    border-radius: var(--radius-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .valore-card:hover {
    border-color: var(--color-orange);
    box-shadow: var(--shadow-md);
  }

  .valore-card__number {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 800;
    color: var(--color-gray-light);
    line-height: 1;
  }

  .valore-card__title {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-dark);
  }

  .valore-card__desc {
    font-size: var(--text-base);
    color: var(--color-gray-mid);
    line-height: 1.7;
  }

  /* CTA BLOCK */
  .cta-block__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    max-width: 600px;
    margin-inline: auto;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .visione__inner { grid-template-columns: 1fr; }
    .visione__decoration { max-width: 320px; }
    .formazione__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .storia__inner { grid-template-columns: 1fr; }
    .storia__photo { order: -1; }
    .storia__photo-placeholder { max-width: 100%; aspect-ratio: 4/3; }
    .valori__grid { grid-template-columns: 1fr; }
    .formazione__grid { grid-template-columns: 1fr; }
  }
</style>
