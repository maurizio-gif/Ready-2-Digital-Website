---
import BaseLayout from '../layouts/BaseLayout.astro';
import NodeDecoration from '../components/NodeDecoration.astro';
import { withBase } from '../utils/url';

const articles = [
  {
    category: 'Punto di vista',
    title: 'Digitalizzazione è strategia, non tecnologia',
    excerpt: 'Perché implementare uno strumento senza una visione di processo produce sempre risultati parziali — e cosa fare invece.',
  },
  {
    category: 'Metodo',
    title: 'L\'audit: il passaggio che cambia tutto',
    excerpt: 'Non è una consulenza teorica. È lo scavo dentro l\'azienda da cui nasce ogni soluzione. Come lo conduciamo.',
  },
  {
    category: 'CRM',
    title: 'Perché la maggior parte dei CRM resta vuota',
    excerpt: 'Non è colpa del software. È colpa di come viene scelto e implementato. Il problema dei processi, non degli strumenti.',
  },
  {
    category: 'AI',
    title: 'AI dove crea valore reale. E dove no.',
    excerpt: 'L\'intelligenza artificiale amplifica quello che c\'è: se c\'è ordine, amplifica l\'efficienza. Se c\'è disordine, amplifica il disordine.',
  },
  {
    category: 'Vendita servizi',
    title: 'Vendere servizi online non è vendere prodotti',
    excerpt: 'Prenotazioni, abbonamenti ricorrenti, pagamenti automatizzati: perché serve una piattaforma, non un catalogo.',
  },
  {
    category: 'Fitness & Sport',
    title: 'Digitalizzare un club dall\'interno',
    excerpt: 'Cosa significa ripensare i processi di una palestra o di un centro sportivo quando li vivi ogni giorno, non da consulente esterno.',
  },
];
---

<BaseLayout
  title="Insights"
  description="Il punto di vista di Ready2Digital sulla digitalizzazione dei processi: strategia, architettura, metodo. Analisi e riflessioni dal campo, non dalla teoria."
>

  <!-- HERO -->
  <section class="page-hero" style="background: var(--color-dark);">
    <div class="hero__bg-decoration float-soft" aria-hidden="true">
      <NodeDecoration color="rgba(255,96,0,0.10)" animated={true} />
    </div>
    <div class="container page-hero__content" data-stagger="120">
      <span class="eyebrow" data-animate="fade-up">Il nostro punto di vista</span>
      <h1 class="page-hero__title" data-animate="clip-up">Idee dal campo,<br>non dalla teoria</h1>
      <p class="page-hero__sub" data-animate="fade-up">
        Come pensiamo la digitalizzazione dei processi: strategia prima degli strumenti,
        architettura prima della tecnologia. Riflessioni, analisi e principi che guidano
        il nostro lavoro.
      </p>
    </div>
  </section>

  <!-- COMING SOON NOTE -->
  <section class="section-sm insights-note">
    <div class="container">
      <div class="insights-note__inner reveal">
        <span class="insights-note__badge">In arrivo</span>
        <p>
          La nostra sezione editoriale è in fase di lancio. Qui pubblicheremo
          il punto di vista di Ready2Digital sui temi che contano davvero.
          Ecco di cosa parleremo.
        </p>
      </div>
    </div>
  </section>

  <!-- ARTICLES GRID -->
  <section class="section insights-grid-section" style="background: var(--color-light); padding-top: 0;">
    <div class="container">
      <div class="insights-grid" data-stagger="100">
        {articles.map(a => (
          <article class="insight-card reveal">
            <div class="insight-card__top">
              <span class="insight-card__category">{a.category}</span>
              <span class="insight-card__soon">In arrivo</span>
            </div>
            <h2 class="insight-card__title">{a.title}</h2>
            <p class="insight-card__excerpt">{a.excerpt}</p>
            <span class="insight-card__meta">Presto disponibile</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- MANIFESTO CLOSING -->
  <section class="section manifesto" style="background: var(--color-dark);">
    <div class="container manifesto__inner" data-stagger="120">
      <span class="eyebrow" data-animate="fade-up">Ready2Digital</span>
      <h2 class="manifesto__quote" data-animate="clip-up">
        "Partiamo sempre dall'obiettivo.<br>La tecnologia viene dopo."
      </h2>
      <p class="manifesto__attr" data-animate="fade-up">Il principio che guida ogni nostro progetto.</p>
    </div>
  </section>

</BaseLayout>

<style>
  .page-hero {
    position: relative;
    padding-block: clamp(var(--space-16), 10vw, var(--space-24));
    overflow: hidden;
    color: var(--color-white);
  }

  .hero__bg-decoration {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .page-hero__content {
    position: relative;
    z-index: 1;
    max-width: 720px;
  }

  .page-hero__title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-4xl), 7vw, var(--text-6xl));
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--color-white);
    margin-top: var(--space-4);
  }

  .page-hero__sub {
    margin-top: var(--space-6);
    font-size: var(--text-xl);
    color: rgba(255,255,255,0.72);
    max-width: 600px;
    line-height: 1.65;
  }

  /* NOTE */
  .insights-note__inner {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    max-width: 760px;
    flex-wrap: wrap;
  }

  .insights-note__badge {
    flex-shrink: 0;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-orange);
    border: 1px solid var(--color-orange);
    border-radius: 999px;
    padding: 0.35rem 0.85rem;
  }

  .insights-note__inner p {
    font-size: var(--text-lg);
    color: var(--color-gray-mid);
    line-height: 1.7;
    flex: 1;
    min-width: 280px;
  }

  /* GRID */
  .insights-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .insight-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-8);
    background: var(--color-white);
    border: 1px solid var(--color-gray-light);
    border-radius: var(--radius-xl);
    transition: border-color var(--transition-base), box-shadow var(--transition-base), transform var(--transition-base);
  }

  .insight-card:hover {
    border-color: var(--color-orange);
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }

  .insight-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .insight-card__category {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-orange);
  }

  .insight-card__soon {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-gray-mid);
    background: var(--color-light);
    border-radius: 999px;
    padding: 0.2rem 0.6rem;
  }

  .insight-card__title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-dark);
    line-height: 1.25;
  }

  .insight-card__excerpt {
    font-size: var(--text-sm);
    color: var(--color-gray-mid);
    line-height: 1.65;
    flex: 1;
  }

  .insight-card__meta {
    font-size: var(--text-xs);
    color: var(--color-gray-mid);
    opacity: 0.7;
    margin-top: auto;
  }

  /* MANIFESTO */
  .manifesto__inner {
    text-align: center;
    max-width: 800px;
    margin-inline: auto;
  }

  .manifesto__inner .eyebrow {
    color: var(--color-orange);
  }

  .manifesto__quote {
    font-family: var(--font-display);
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-white);
    margin-top: var(--space-4);
  }

  .manifesto__attr {
    margin-top: var(--space-6);
    font-size: var(--text-lg);
    color: rgba(255,255,255,0.6);
  }

  @media (max-width: 1024px) {
    .insights-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .insights-grid { grid-template-columns: 1fr; }
  }
</style>
