---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const integrazioni = [
  { name: 'Stripe', desc: 'Pagamenti su carta, abbonamenti ricorrenti' },
  { name: 'GoCardless', desc: 'Addebito su conto corrente (SEPA Direct Debit)' },
  { name: 'CRM custom', desc: 'Sync automatico dei dati clienti' },
  { name: 'Software gestionali', desc: 'Integrazione con i sistemi esistenti' },
];
---

<ServiceLayout
  title="Piattaforme di Vendita Servizi"
  description="Un sistema di vendita servizi non è un catalogo prodotti. Prenotazioni eventi, abbonamenti ricorrenti, pagamenti automatizzati, CRM integrato."
  eyebrow="Vendita di servizi online"
  headline="Vendi servizi, eventi,<br>abbonamenti. Online."
  intro="Un sistema di vendita servizi non è un catalogo di prodotti. È una piattaforma che gestisce prenotazioni, abbonamenti ricorrenti e connessioni con i sistemi di pagamento."
>

  <section class="section body-section">
    <div class="container">
      <div class="two-col reveal">
        <div class="two-col__text">
          <p class="body-lead">
            Sviluppiamo piattaforme native che connettono la vendita del servizio con la gestione
            dell'evento, l'automazione dei pagamenti ricorrenti, la comunicazione automatica con
            i clienti, e i dati che alimentano il CRM.
          </p>
        </div>
        <div class="flow-box reveal">
          <h3 class="flow-box__title">Come funziona in pratica</h3>
          <div class="flow-steps stagger-list">
            <div class="flow-step">
              <div class="flow-step__num">1</div>
              <p>Cliente prenota un evento attraverso la piattaforma</p>
            </div>
            <div class="flow-arrow">↓</div>
            <div class="flow-step">
              <div class="flow-step__num">2</div>
              <p>Paga con Stripe o GoCardless (carta o conto corrente)</p>
            </div>
            <div class="flow-arrow">↓</div>
            <div class="flow-step">
              <div class="flow-step__num">3</div>
              <p>Riceve conferma automatica via email/SMS</p>
            </div>
            <div class="flow-arrow">↓</div>
            <div class="flow-step">
              <div class="flow-step__num">4</div>
              <p>Il dato entra nel CRM — storico aggiornato in tempo reale</p>
            </div>
            <div class="flow-arrow">↓</div>
            <div class="flow-step">
              <div class="flow-step__num">5</div>
              <p>Il team vede iscritti, posti disponibili, storico clienti</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section integrazioni-section" style="background: var(--color-light);">
    <div class="container">
      <div class="reveal">
        <span class="eyebrow">Integrazioni supportate</span>
        <h2 class="section-title">Pagamenti e sistemi<br>già integrati</h2>
        <div class="divider"></div>
      </div>
      <div class="integrazioni-grid" data-stagger="120">
        {integrazioni.map(i => (
          <div class="integrazione-card reveal">
            <h3 class="integrazione-card__name">{i.name}</h3>
            <p class="integrazione-card__desc">{i.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</ServiceLayout>

<style>
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  .two-col__text { display: flex; flex-direction: column; gap: var(--space-6); }

  .body-lead {
    font-size: var(--text-xl);
    color: var(--color-charcoal);
    line-height: 1.75;
  }

  .flow-box {
    background: var(--color-light);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
  }

  .flow-box__title {
    font-size: var(--text-xl);
    font-weight: 700;
    margin-bottom: var(--space-6);
    color: var(--color-dark);
  }

  .flow-steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .flow-step {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    background: var(--color-white);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }

  .flow-step__num {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--color-orange);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-sm);
    font-weight: 700;
    flex-shrink: 0;
  }

  .flow-step p {
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    line-height: 1.5;
  }

  .flow-arrow {
    text-align: center;
    color: var(--color-gray-mid);
    font-size: var(--text-sm);
    padding-left: var(--space-8);
  }

  .integrazioni-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    margin-top: var(--space-10);
  }

  .integrazione-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-light);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .integrazione-card:hover {
    border-color: var(--color-orange);
    box-shadow: var(--shadow-md);
  }

  .integrazione-card__name {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: var(--space-3);
  }

  .integrazione-card__desc {
    font-size: var(--text-base);
    color: var(--color-gray-mid);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .two-col { grid-template-columns: 1fr; }
    .integrazioni-grid { grid-template-columns: 1fr; }
  }
</style>
