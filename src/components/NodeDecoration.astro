---
interface Props {
  color?: string;
  opacity?: number;
  animated?: boolean;
}
const { color = 'rgba(255,96,0,0.08)', opacity = 1, animated = false } = Astro.props;
---
<svg
  class:list={['node-decoration', { 'node-decoration--animated': animated }]}
  style={`opacity: ${opacity}`}
  viewBox="0 0 600 400"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <!-- Connecting lines -->
  <g class="nd-lines" stroke={color}>
    <line x1="80"  y1="200" x2="200" y2="80"  stroke-width="1.5"/>
    <line x1="80"  y1="200" x2="200" y2="320" stroke-width="1.5"/>
    <line x1="200" y1="80"  x2="320" y2="160" stroke-width="1.5"/>
    <line x1="200" y1="320" x2="320" y2="280" stroke-width="1.5"/>
    <line x1="320" y1="160" x2="440" y2="100" stroke-width="1.5"/>
    <line x1="320" y1="160" x2="440" y2="240" stroke-width="1.5"/>
    <line x1="320" y1="280" x2="440" y2="240" stroke-width="1.5"/>
    <line x1="440" y1="100" x2="520" y2="320" stroke-width="1.5"/>
    <line x1="440" y1="240" x2="520" y2="320" stroke-width="1.5"/>
    <line x1="200" y1="80"  x2="140" y2="140" stroke-width="1"/>
    <line x1="320" y1="280" x2="380" y2="360" stroke-width="1"/>
  </g>
  <!-- Node circles -->
  <g class="nd-nodes" fill={color}>
    <circle cx="80"  cy="200" r="10"/>
    <circle cx="200" cy="80"  r="8"/>
    <circle cx="200" cy="320" r="8"/>
    <circle cx="320" cy="160" r="12"/>
    <circle cx="320" cy="280" r="8"/>
    <circle cx="440" cy="100" r="8"/>
    <circle cx="440" cy="240" r="10"/>
    <circle cx="520" cy="320" r="6"/>
    <circle cx="140" cy="140" r="5"/>
    <circle cx="380" cy="360" r="6"/>
  </g>
</svg>

<style>
  .node-decoration {
    pointer-events: none;
    width: 100%;
    height: 100%;
  }

  /* Animated variant: nodes pulse, lines draw in */
  .node-decoration--animated .nd-nodes circle {
    transform-box: fill-box;
    transform-origin: center;
    animation: pulse-node 4s ease-in-out infinite;
  }
  .node-decoration--animated .nd-nodes circle:nth-child(2n)  { animation-delay: 0.6s; }
  .node-decoration--animated .nd-nodes circle:nth-child(3n)  { animation-delay: 1.2s; }
  .node-decoration--animated .nd-nodes circle:nth-child(4n)  { animation-delay: 1.8s; }
  .node-decoration--animated .nd-nodes circle:nth-child(5n)  { animation-delay: 2.4s; }

  .node-decoration--animated .nd-lines line {
    stroke-dasharray: 200;
    stroke-dashoffset: 200;
    animation: dash-draw 3s var(--ease-out-expo) forwards;
  }
  .node-decoration--animated .nd-lines line:nth-child(2n) { animation-delay: 0.4s; }
  .node-decoration--animated .nd-lines line:nth-child(3n) { animation-delay: 0.8s; }

  @media (prefers-reduced-motion: reduce) {
    .node-decoration--animated .nd-nodes circle,
    .node-decoration--animated .nd-lines line {
      animation: none;
      stroke-dashoffset: 0;
    }
  }
</style>
