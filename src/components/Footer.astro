---
import { withBase } from '../utils/url';

const servizi = [
  { label: 'Audit e Process Architecture', href: '/servizi/audit' },
  { label: 'Web & App Custom', href: '/servizi/web-app' },
  { label: 'Piattaforme di Vendita Servizi', href: '/servizi/ecommerce' },
  { label: 'CRM Custom', href: '/servizi/crm' },
  { label: 'AI & Automazione', href: '/servizi/ai-automazione' },
  { label: 'Software Gestionali', href: '/servizi/software-gestionali' },
  { label: 'Hardware & Soluzioni Immersive', href: '/servizi/hardware' },
];
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href={withBase('/')} aria-label="Ready2Digital Home">
        <img
          src={withBase('/images/logo_r2digital.png')}
          alt="R2Digital"
          width="140"
          height="36"
          loading="lazy"
        />
      </a>
      <p class="footer__tagline">Architettura dei Processi Digitali</p>
      <div class="footer__social">
        <!-- LinkedIn -->
        <a href="#" aria-label="LinkedIn" class="footer__social-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <!-- Instagram -->
        <a href="#" aria-label="Instagram" class="footer__social-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="footer__col">
      <h4>Servizi</h4>
      <ul>
        {servizi.map(s => (
          <li><a href={withBase(s.href)}>{s.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer__col">
      <h4>Azienda</h4>
      <ul>
        <li><a href={withBase('/chi-siamo')}>Chi Siamo</a></li>
        <li><a href={withBase('/servizi')}>Tutti i Servizi</a></li>
        <li><a href={withBase('/insights')}>Insights</a></li>
        <li><a href={withBase('/contatti')}>Contatti</a></li>
      </ul>
    </div>

    <div class="footer__col">
      <h4>Contatti</h4>
      <ul>
        <li>
          <a href="mailto:info@ready2digital.it">info@ready2digital.it</a>
        </li>
        <li>Italia</li>
      </ul>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p>&copy; 2024 Ready2Digital. Tutti i diritti riservati.</p>
      <a href={withBase('/en/')} class="footer__lang">EN</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-charcoal);
    color: rgba(255,255,255,0.75);
    padding-top: var(--space-16);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 0.8fr 1fr;
    gap: var(--space-12);
    padding-bottom: var(--space-12);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .footer__brand img {
    /* Logo is dark charcoal; render it white so it reads on the dark footer */
    filter: brightness(0) invert(1);
    opacity: 0.92;
    margin-bottom: var(--space-4);
    height: 34px;
    width: auto;
  }

  .footer__tagline {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.5);
    margin-bottom: var(--space-6);
  }

  .footer__social {
    display: flex;
    gap: var(--space-4);
  }

  .footer__social-link {
    color: rgba(255,255,255,0.5);
    transition: color var(--transition-fast);
  }

  .footer__social-link:hover {
    color: var(--color-orange);
  }

  .footer__col h4 {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: var(--space-5);
  }

  .footer__col ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__col a,
  .footer__col li {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.7);
    transition: color var(--transition-fast);
    line-height: 1.4;
  }

  .footer__col a:hover {
    color: var(--color-white);
  }

  .footer__cta {
    margin-top: var(--space-6);
    font-size: var(--text-sm);
    padding: 0.625rem 1.25rem;
  }

  .footer__bottom {
    padding-block: var(--space-5);
  }

  .footer__bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer__bottom p {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.4);
  }

  .footer__lang {
    font-size: var(--text-sm);
    font-weight: 600;
    color: rgba(255,255,255,0.4);
    transition: color var(--transition-fast);
    border: 1px solid rgba(255,255,255,0.2);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
  }

  .footer__lang:hover {
    color: var(--color-white);
    border-color: rgba(255,255,255,0.4);
  }

  @media (max-width: 1024px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-10);
    }
  }

  @media (max-width: 640px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
