---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
}
const { title, description, href, icon } = Astro.props;
---

<a href={href} class="service-card reveal">
  <div class="service-card__icon" aria-hidden="true" set:html={icon}></div>
  <h3 class="service-card__title">{title}</h3>
  <p class="service-card__desc">{description}</p>
  <span class="service-card__link">Scopri di più →</span>
</a>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-8);
    border: 1px solid var(--color-gray-light);
    border-radius: var(--radius-xl);
    background: var(--color-white);
    transition: all var(--transition-base);
    text-decoration: none;
    color: inherit;
  }

  .service-card:hover {
    border-color: var(--color-orange);
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }

  .service-card__icon {
    width: 48px;
    height: 48px;
    color: var(--color-orange);
    flex-shrink: 0;
  }

  .service-card__title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-dark);
  }

  .service-card__desc {
    font-size: var(--text-sm);
    color: var(--color-gray-mid);
    line-height: 1.6;
    flex: 1;
  }

  .service-card__link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-orange);
    margin-top: auto;
    transition: gap var(--transition-fast);
  }
</style>
